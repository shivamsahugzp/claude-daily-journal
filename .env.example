# ── Claude API (required) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Research (optional — improves content quality) ──────────────────────────
# Free 100 searches/month: https://serper.dev
SERPER_API_KEY=

# ── Publishing: dev.to ───────────────────────────────────────────────────────
# Get from: https://dev.to/settings/extensions → API Keys
DEVTO_API_KEY=

# ── Publishing: Hashnode ─────────────────────────────────────────────────────
# Token: https://hashnode.com/settings/developer
# Publication ID: your blog's publication ID (from dashboard URL)
HASHNODE_TOKEN=
HASHNODE_PUBLICATION_ID=

# ── Publishing: Twitter/X ────────────────────────────────────────────────────
# Apply at: https://developer.twitter.com/en/portal/dashboard
# Free tier: 500 posts/month (plenty)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# ── Publishing: Meta Threads ─────────────────────────────────────────────────
# Get from: https://developers.facebook.com → Threads API
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── Publishing: Instagram ────────────────────────────────────────────────────
# Requires: Instagram Business account + Facebook Developer App
# Guide: https://developers.facebook.com/docs/instagram-api
IG_USER_ID=
IG_ACCESS_TOKEN=

# ── Publishing: LinkedIn ──────────────────────────────────────────────────────
# Apply at: https://developer.linkedin.com
# Scopes needed: w_member_social, r_liteprofile
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXX
